# Google Cloud Vision API 서비스 계정 키
# Google Cloud Console에서 다운로드한 JSON 키의 내용을 아래에 붙여넣으세요.
# ⚠️ 이 파일은 .gitignore에 포함되어 git에 올라가지 않습니다.

[gcp_service_account]
type = "service_account"
project_id = "여기에-프로젝트-ID"
private_key_id = "여기에-키-ID"
private_key = "-----BEGIN PRIVATE KEY-----\n여기에-비공개키\n-----END PRIVATE KEY-----\n"
client_email = "여기에@프로젝트.iam.gserviceaccount.com"
client_id = "여기에-클라이언트-ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "여기에-인증서-URL"
